                            "mgmtd": {
                                "9000_allow_responses": {
                                    "notes": "Allow outgoing traffic created in response to connections accepted by input\nchain. This rule is not needed as long as policy of this chain is accept --- it\nis present here for convenience because continuation of already established\nconnection is almost always something we want, and it is easy to forget adding\nsuch rule after changing policy of the chain to `drop`. The name starts with\n9000_ as it is meant to be executed late in the chain (so earlier explicit drops\nwill prevent triggering this rule)",
                                    "contents": "ct state {related, established} accept"
                                }
                            },
                            "policy": "accept"
                        },
                        "forward": {
