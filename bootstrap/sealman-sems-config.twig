​{
    "azure": {
        "config": {
            "hostname": "eg-{{serialNumber}}",
            "provisioning": {
                "source":"manual",
                "connection_string":"{{device_connection_string}}"
            },
            "agent": {
                "name": "edgeAgent",
                "type": "docker",
                "config": {
                    "image": "{{edge_agent_image}}",
                    "auth": {
                        "serveraddress": "{{container_registry_address}}",
                        "username": "{{container_registry_username}}",
                        "password": "{{container_registry_password}}"
                    }
                }
            }
        },
        "validated": "1"
    },
    "config_format_version": "1.0",
    "serial": {
        "serial0": {
            "console_output": {
                "at_startup": false,
                "currently": false
            }
        }
    },
    "logrotate": {
        "rotate": 14,
        "period": "daily",
        "maxsize": 50
    },
    "user_password_hashes": {
        {% if adminCryptSha512 is defined %}
        "admin": "{{adminCryptSha512}}"
        {% else %}
        "admin": "$6$vqNLBUNp3syly3p2$xxR7Njt/1kKAym.6/dQN5OxB/D9QpHYNJlsP14k8eqN6eaIVPTAjL7faP7Y/TNlPxxnRZOdS75d93DQJBsPYe/"
        {% endif %}
    },
    "sshconfig": {
        "password_auth": "on",
        "key_auth": "on",
        "publickeys": {
            "admin": []
         },
        "unreadable_users": {}
    },
    "proxy_servers": {},
    "motd": "",
    "date_time": {
        "ntp_server": "",
        "fallback_servers": "0.de.pool.ntp.org 1.de.pool.ntp.org 2.de.pool.ntp.org 3.de.pool.ntp.org",
        "interval_minimum": 32,
        "interval_maximum": 2048,
        "ntp_enabled": true,
        "timezone": "Universal"
    },
    "webgui": {
        "is_enabled": true
    },
    "network": {
		{% if cellular is defined and cellular_settings is defined %}
		"cellular1": {{ cellular_settings | json_encode | raw }},
		{% endif %}
        "lan1": {
            "dhcp": false,
            "ip": [
                "192.168.2.1"
            ],
            "subnet": [
                "24"
            ],
            "gateway": null,
            "dns": null,
            "current_ip": "192.168.2.1",
            "current_subnet": "24",
            "current_gateway": null,
            "current_dns": null
        },
		{% if lan_settings is defined and lan_settings.lan2 is defined %}
		"lan2": {{ lan_settings.lan2 | json_encode | raw }},
		{% else %}
		"lan2": {
            "dhcp": true,
            "ip": [],
            "subnet": [],
            "gateway": null,
            "dns": null
		},
		{% endif %}
		{% if lan_settings is defined and lan_settings.lan3 is defined %}
		"lan3": {{ lan_settings.lan3 | json_encode | raw }}
		{% else %}
		"lan3": {
            "dhcp": true,
            "ip": [],
            "subnet": [],
            "gateway": null,
            "dns": null
		}
		{% endif %}
    },
    "vlans": {
        "lan2": {
            {% if nat_settings is defined and nat_settings.enabled %}
            {% for m in nat_settings.mappings %}
            "lan2_{{ loop.index }}": {
                "ip": "{{ m.externalIp }}",
                "subnet": 32,
                "gateway": ""
            }{% if not loop.last %},{% endif %}
            {% endfor %}
            {% endif %}
	    },
        "lan3": {},
        "lan1": {}
    },
    "static_routing": {
        "enabled": false,
        "selected": "disabled",
        "saved": {
            "disabled": {}
        },
        "edited": {}
    },
    "firewall": {
        "enabled": true,
        "selected": "fw_preset",
        "edited": {},
        "saved": {
            "fw_preset": {
                "notes": "default preset",
                "ip": {
                    "nat": {
                        "prerouting": {
                            "mgmtd": {
                                {% if port_forwarding_settings is defined %}
								{# --- Port forwarding rules --- #}
								{% for r in port_forwarding_settings.rules %}
								"{{ 100 + loop.index }}_{{ r.name }}": {
								  "contents": "iifname {{ r.interface }} tcp dport {{ r.srcPort }} dnat to {{ r.destAddr }}:{{ r.destPort }}"
								}{% if not loop.last or (nat_settings is defined and nat_settings.enabled and nat_settings.mappings|length > 0) %},{% endif %}
								{% endfor %}
								{% endif %}
								{# --- NAT rules --- #}
								{% if nat_settings is defined and nat_settings.enabled %}
									{% for m in nat_settings.mappings %}
									"{{ 1100 + loop.index * 100 }}_{{ m.name }}": {
									  "contents": "ip daddr {{ m.externalIp }} dnat to {{ m.internalIp }}"
									}{% if not loop.last %},{% endif %}
									{% endfor %}
								{% endif %}
                            },
                            "policy": "accept"
                        },
                        "postrouting": {
                            "mgmtd": {
                                "1000_masquerade_cellular1": {
                                    "contents": "oifname cellular1 masquerade",
                                    "notes": "We treat lan2 (which by default receives address from DHCP) and cellular1 as WAN\ninterfaces, hence be default we masqurade other networks (lan1 and internal\ndocker networks) behind our address visible on lan2 and cellular1.\n\nNote that if you have both lan2 and cellular interfaces active you may want to\nremove one of the masquerade rules, or add a rule preventing routing between\nlan2 and cellular1 which you can do with commands:\nfw modify forward add block_wan_to_wan_1 -i lan2 -o cellular1 -v drop\nfw modify forward add block_wan_to_wan_2 -i cellular1 -o lan2 -v drop\n(assuming you have exactly one preset in being edited state)"
                                },
                                "1100_masquerade_lan2": {
                                    "contents": "oifname lan2 masquerade"
                                },
                                "1200_masquerade_lan3": {
                                    "contents": "oifname lan3 masquerade"
                                }
                                {#- -----Settings 1:1 NAT----- -#}
								{% if nat_settings is defined and nat_settings.enabled and nat_settings.mappings|length > 0 %}
								  ,
								  {% for m in nat_settings.mappings %}
								  "{{ 2100 + loop.index * 100 }}_{{ m.name }}": {
									"contents": "ip saddr {{ m.internalIp }} snat to {{ m.externalIp }}"
								  }{% if not loop.last %},{% endif %}
								  {% endfor %}
								{% endif %}
                            },
                            "policy": "accept"
                        }
                    }
                },
                "inet": {
                    "filter": {
                        "common": {
                            "mgmtd": {
                                "1200_allow_icmp": {
                                    "contents": "meta l4proto {icmp, icmpv6} accept",
                                    "notes": "Allow ICMP everywhere"
                                }
                            }
                        },
                        "input": {
                            "mgmtd": {
                                "1000_allow_local": {
                                    "contents": "iiftype loopback accept",
                                    "notes": "Do not remove this rule unless you want to break device.\n\nThis rule allows any internal traffic (e.g. 127.0.0.1 for IPv4 and ::1 for\nIPv6). Because input policy is 'drop' in this preset, without this rule internal\nservices of EG will stop working."
                                },
                                "1100_allow_ssh": {
                                    "contents": "tcp dport ssh accept"
                                },
                                "1200_allow_https": {
                                    "contents": "tcp dport https accept"
                                },
                                "1300_allow_swupdate": {
                                    "contents": "tcp dport 8080 accept"
                                },
                                "1400_allow_webui": {
                                    "contents": "tcp dport 48366 accept"
                                },
                                "1500_allow_conn_check": {
                                    "contents": "tcp dport 9090 accept"
                                },
                                "1600_allow_all_tun0": {
                                    "contents": "iifname tun0 accept"
                                },
                                "9000_allow_responses": {
                                    "contents": "ct state {related, established} accept",
                                    "notes": "Allow incoming traffic created in response to connections originated by EG itself."
                                }
                            },
                            "policy": "drop"
                        },
                        "output": {
                            "mgmtd": {
                                "9000_allow_responses": {
                                    "notes": "Allow outgoing traffic created in response to connections accepted by input\nchain. This rule is not needed as long as policy of this chain is accept --- it\nis present here for convenience because continuation of already established\nconnection is almost always something we want, and it is easy to forget adding\nsuch rule after changing policy of the chain to `drop`. The name starts with\n9000_ as it is meant to be executed late in the chain (so earlier explicit drops\nwill prevent triggering this rule)",
                                    "contents": "ct state {related, established} accept"
                                }
                            },
                            "policy": "accept"
                        },
                        "forward": {
                            "mgmtd": {
                                "1000_allow_responses": {
                                    "notes": "Allow forwarding traffic created in response to connections accepted by other\nrules. This rule is not needed as long as policy of this chain is accept --- it\nis present here for convenience because continuation of already established\nconnection is almost always something we want, and it is easy to forget adding\nsuch rule after changing policy of the chain to `drop`. The name starts with\n9000_ as it is meant to be executed late in the chain (so earlier explicit drops\nwill prevent triggering this rule)",
                                    "contents": "ct state {related, established} accept"
                                }
                                 {% if custom_fw_allow_http is defined %}
                                ,
                                "1100_allow_http": {"contents": "tcp dport 443 accept"}
                                {% endif %}
                                {% if custom_fw_allow_ftp is defined %}
                                ,
                                "1200_allow_ftp": {"contents": "tcp dport 21 accept"}
                                {% endif %}
                                {% if custom_fw_allow_sftp is defined %}
                                ,
                                "1300_allow_sftp": {"contents": "tcp dport 22 accept"}
                                {% endif %}
                                {% if custom_fw_allow_opc is defined %}
                                ,
                                "1400_fw_allow_opcua_4840": {"contents": "tcp dport 4840 accept"}
                                {% endif %}
                                ,
                                "1500_drop_lan3_to_lan2": {
                                    "contents": "iifname lan3 oifname lan2  drop"
                                }
                            },
                            "policy": "accept"
                        }
                    }
                }
            }
        }
    },
    "ovpn": {},
    "docker": {
        "dockerdns": [],
        "params": {},        
        "compose_files": {
            "seal-app-connection-check": "version: \"3.8\"\n\nservices:\n  backend:\n    image: {{container_registry_address}}/seal-app-connection-check-backend:1.0.1\n    container_name: seal-app-conn-check-api\n    restart: unless-stopped\n    ports:\n      - \"9091:9091\"\n    networks:\n      - \"local-network\"\n    environment:\n      - FLASK_APP=main.py\n      - FLASK_RUN_HOST=0.0.0.0\n      - FLASK_RUN_PORT=9091\n    volumes:\n      - /run/mgmtd:/run/mgmtd\n    tty: true\n    stdin_open: true\n\n  frontend:\n    image: {{container_registry_address}}/seal-app-connection-check-frontend:1.0.1\n    container_name: seal-app-conn-check-ui\n    ports:\n      - \"9090:9090\"\n    networks:\n      - \"local-network\"\n    restart: unless-stopped\n\nnetworks:\n  local-network:\n    driver: \"bridge\""
			},
        "compose_docker_config": {
            "auths": {
                "{{container_registry_address}}": {
                    "auth": "{{container_registry_credentials_encoded}}"
                }
            }
        }
    },
    "smartems": {
        "username": "{{sems_device_user | default('edgeGateway')}}",
        "password": "{{sems_device_password | default('123456')}}",
        "url": "{{sems_device_url}}",
        "pollingInterval": {{ sems_polling_interval | default('600') }},
        "edgegatewayvcc": {{ sems_edgegatewayvcc | default('false') }},
        "certificate": "{{ sems_certificate | default('') }}"
    }
}