# ═══════════════════════════════════════════════════════════════
# GENERAL
# ═══════════════════════════════════════════════════════════════

PORT="5000"
VERSION="local-dev"

ALLOW_INSECURE_HTTPS=true

CORS_ALLOWED_ORIGINS="https://localhost:5173,http://localhost:3000"

API_KEY=
API_KEY_NAME=

ENABLE_WEBHOOK_AUTHORIZATION="false"

# ═══════════════════════════════════════════════════════════════
# IOTHUB
# ═══════════════════════════════════════════════════════════════

IOT_HUB_NAME=
SAS_TOKEN=

INTERNAL_STORAGE_ACCOUNT_NAME=

BLOB_SAS_TOKEN_MODULE_CONF=
BLOB_SAS_TOKEN_WEB_FTP=
BLOB_SAS_TOKEN_TEMPLATES=
BLOB_SAS_TOKEN_IOT_PLATFORM_CONFIGURATION=
BLOB_SAS_TOKEN_MODULE_NEURONEX_MANAGER=
BLOB_SAS_TOKEN_MODULE_MODBUS=
BLOB_SAS_TOKEN_MODULE_VSE=
BLOB_SAS_TOKEN_SEMS_TEMPLATE=

BLOB_STORAGE_ACCOUNT_IOT_PLATFORM_CONFIGURATION=

DEFAULT_SEMS_TEMPLATE_BLOB_CONTAINER_NAME=
DEFAULT_SEMS_TEMPLATE_BLOB_FILE_NAME=

COSMOS_DB_CONNECTION_STRING=
PUBLIC_STORAGE_ACCOUNT_NAME=
TABLE_STORAGE_ACCOUNT=
RENEW_TASK_SCHEDULE_TABLE=
TABLE_SAS_TOKEN_PASSWORD_RENEWAL=

POWER_AUTOMATE_SCOPE=
EDGE_PASS_REQUEST_URL=

# ═══════════════════════════════════════════════════════════════
# SEALMAN EMS
# ═══════════════════════════════════════════════════════════════

SEMS_URL="https://sems.localhost"
SEMS_USER="admin123"
SEMS_PW="admin123"

SEMS_LOOKUP_INTERVAL="3600"

SEMS_INIT_FUNCTION_URL=""
SEMS_INIT_FUNCTION_KEY=""

# ═══════════════════════════════════════════════════════════════
# AUTHENTICATION
# ═══════════════════════════════════════════════════════════════

AUTHENTICATION_PROVIDER="keycloak"

KEYCLOAK_BASE_URL="https://keycloak.localhost"
KEYCLOAK_REALM="local-dev"
KEYCLOAK_CLIENT_ID="ec-api"

AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_SCOPES=

AUTHORIZATION_API=
AUTHORIZATION_API_SCOPE=

# ═══════════════════════════════════════════════════════════════
# REMOTE CONTROL
# ═══════════════════════════════════════════════════════════════

REMOTE_CTRL_KEY=
REMOTE_CTRL_KEY_NAME=
REMOTE_CTRL_FWD_ENDPOINT=
REMOTE_CTRL_API_ENDPOINT=

RC_BASIC_AUTH_USER=
RC_BASIC_AUTH_PW=

# ═══════════════════════════════════════════════════════════════
# DATABASE
# ═══════════════════════════════════════════════════════════════

POSTGRES_URL="postgresql+psycopg://postgres:postgres@localhost:5432/postgres"
